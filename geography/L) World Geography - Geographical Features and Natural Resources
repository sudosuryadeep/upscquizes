let S={cur:0,ans:new Array(34).fill(null),skp:new Array(34).fill(false),start:null,tLeft:25*60,tInt:null,done:false};
const pad=n=>String(n).padStart(2,'0');

function startQuiz(){
  const raw=localStorage.getItem('geomind_v1');
  if(raw){
    const d=JSON.parse(raw);
    if(!d.done&&confirm('Resume your previous session?')){
      S={...S,...d,tInt:null};
    }else{localStorage.removeItem('geomind_v1');S.start=Date.now();}
  }else{S.start=Date.now();}
  show('quiz');buildDots();renderQ();runTimer();
}

function show(id){
  document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));
  document.getElementById(id).classList.add('active');
  window.scrollTo(0,0);
}

function runTimer(){
  if(S.tInt)clearInterval(S.tInt);
  updTimer();
  S.tInt=setInterval(()=>{
    if(S.done){clearInterval(S.tInt);return;}
    S.tLeft--;updTimer();
    if(S.tLeft%20===0)save();
    if(S.tLeft<=0){clearInterval(S.tInt);alert('Time is up! Submitting…');submitQuiz();}
  },1000);
}
function updTimer(){
  const m=Math.floor(S.tLeft/60),s=S.tLeft%60;
  const el=document.getElementById('timerEl');
  el.textContent=`${pad(m)}:${pad(s)}`;
  el.className=S.tLeft<=300?'q-timer hot':'q-timer';
}

function renderQ(){
  const i=S.cur,q=Q[i];
  document.getElementById('qCur').textContent=i+1;
  document.getElementById('qTot').textContent=Q.length;
  document.getElementById('qBadge').textContent='Q'+String(i+1).padStart(2,'0');
  document.getElementById('qYr').textContent=q.yr;
  document.getElementById('qTopic').textContent=q.topic;
  document.getElementById('qBody').textContent=q.text;
  document.getElementById('pFill').style.width=((i+1)/Q.length*100)+'%';

  const sp=document.getElementById('qStat');
  if(S.skp[i]){sp.textContent='Skipped';sp.className='q-status-tag qs-skp';}
  else if(S.ans[i]!==null){sp.textContent='Answered';sp.className='q-status-tag qs-ans';}
  else{sp.textContent='Unanswered';sp.className='q-status-tag qs-none';}

  // Map
  const ma=document.getElementById('mapArea');
  if(q.mapImg){
    const mi=document.getElementById('mapImg');
    mi.classList.remove('in');
    mi.src=q.mapImg;
    document.getElementById('mapCap').textContent=q.mapCap||'';
    ma.style.display='block';
  }else{ma.style.display='none';}

  // Options
  const og=document.getElementById('optsGrid');og.innerHTML='';
  q.opts.forEach((o,idx)=>{
    const b=document.createElement('button');
    b.className='opt'+(S.ans[i]===idx?' sel':'');
    b.innerHTML=`<span class="opt-ltr">${L[idx]}</span><span>${o}</span>`;
    b.onclick=()=>pick(idx);
    og.appendChild(b);
  });

  document.getElementById('btnPrev').disabled=(i===0);
  const last=(i===Q.length-1);
  document.getElementById('btnNext').style.display=last?'none':'inline-block';
  document.getElementById('btnSub').style.display=last?'inline-block':'none';
  updDots();
}

function pick(idx){if(S.done)return;S.ans[S.cur]=idx;S.skp[S.cur]=false;renderQ();save();}
function go(d){const n=S.cur+d;if(n>=0&&n<Q.length){S.cur=n;renderQ();}}
function skipQ(){S.skp[S.cur]=true;S.ans[S.cur]=null;save();if(S.cur<Q.length-1)go(1);else renderQ();}

function buildDots(){
  const dm=document.getElementById('dotMap');dm.innerHTML='';
  Q.forEach((_,i)=>{
    const d=document.createElement('button');
    d.className='dot';d.textContent=i+1;d.id=`d${i}`;
    d.onclick=()=>{S.cur=i;renderQ();};dm.appendChild(d);
  });
}
function updDots(){
  Q.forEach((_,i)=>{
    const d=document.getElementById(`d${i}`);if(!d)return;
    d.className='dot';
    if(i===S.cur)d.classList.add('cur');
    else if(S.skp[i])d.classList.add('d-skp');
    else if(S.ans[i]!==null)d.classList.add('d-ans');
  });
}

function showMod(){
  const a=S.ans.filter(x=>x!==null).length;
  const sk=S.skp.filter(Boolean).length;
  const un=Q.length-a-sk;
  document.getElementById('modTxt').textContent=`Answered: ${a}  ·  Skipped: ${sk}  ·  Unanswered: ${un}\n\nOnce submitted, answers cannot be changed.`;
  document.getElementById('modalOv').classList.add('on');
}
function closeMod(){document.getElementById('modalOv').classList.remove('on');}

function submitQuiz(){
  closeMod();clearInterval(S.tInt);S.done=true;
  const used=(25*60)-S.tLeft;
  let cor=0,wr=0,sk=0;
  Q.forEach((q,i)=>{
    if(S.skp[i]||S.ans[i]===null)sk++;
    else if(S.ans[i]===q.ans)cor++;
    else wr++;
  });
  const attempted=cor+wr;
  const pct=Math.round(cor/Q.length*100);
  const acc=attempted?Math.round(cor/attempted*100):0;

  let grade,gc;
  if(pct>=90){grade='Outstanding';gc='#2d6a4f';}
  else if(pct>=75){grade='Excellent';gc='#1d6fa0';}
  else if(pct>=60){grade='Good';gc='#6b4fcc';}
  else if(pct>=45){grade='Average';gc='#b8860b';}
  else{grade='Keep Revising';gc='#c84b2f';}

  document.getElementById('rScore').textContent=cor;
  const gp=document.getElementById('rGrade');
  gp.textContent=grade;
  gp.style.cssText=`background:${gc}18;color:${gc};border:1px solid ${gc}40;font-family:'Playfair Display',serif;font-weight:700`;
  document.getElementById('rSub').textContent=`${pct}% · ${cor} correct out of ${Q.length}`;

  if(pct>=75){document.getElementById('rMsg').textContent='Strong performance! Your world geography knowledge is solid.';}
  else if(pct>=50){document.getElementById('rMsg').textContent='Decent attempt. Review the weak areas below and revise systematically.';}
  else{document.getElementById('rMsg').textContent='More revision needed. Start with atlas practice and key geographic facts.';}

  document.getElementById('stC').textContent=cor;
  document.getElementById('stW').textContent=wr;
  document.getElementById('stS').textContent=sk;
  document.getElementById('stAcc').textContent=acc+'%';
  document.getElementById('stTime').textContent=fmtT(used);
  document.getElementById('stAvg').textContent=Math.round(used/Q.length)+'s';

  buildInsights(cor,wr,sk,pct,acc,attempted);
  renderRev('all');
  localStorage.removeItem('geomind_v1');
  show('results');
}
function fmtT(s){return `${Math.floor(s/60)}:${pad(s%60)}`;}

function buildInsights(cor,wr,sk,pct,acc,attempted){
  const topErr={};
  Q.forEach((q,i)=>{
    if(!S.skp[i]&&S.ans[i]!==null&&S.ans[i]!==q.ans)
      topErr[q.topic]=(topErr[q.topic]||0)+1;
  });
  const ranked=Object.entries(topErr).sort((a,b)=>b[1]-a[1]);
  const lines=[];

  if(pct>=90)lines.push('Exceptional mastery of world geography. UPSC-ready performance.');
  else if(pct>=75)lines.push('Strong result. A few targeted revisions will make you exam-ready.');
  else if(pct>=50)lines.push('Good base. Revise mineral producers, river courses, and world landforms.');
  else lines.push('Begin with NCERT Class 11 Fundamentals of Physical Geography and an atlas before retrying.');

  if(sk>6)lines.push(`${sk} questions skipped. Practice educated elimination — partial knowledge can still yield correct answers.`);
  if(attempted>0&&acc<55&&attempted>6)lines.push(`Accuracy ${acc}% among attempted. Avoid guessing; use elimination carefully.`);

  if(topErr['World Geography']||topErr['World Landforms'])lines.push('Revise key world landforms: mountain ranges, deserts, highlands, trenches.');
  if(topErr['Minerals & Resources']||topErr['Minerals & Producers'])lines.push('Mineral producers: DRC=Cobalt, Chile=Copper, Australia=Uranium, Venezuela=Oil, Zambia=Copper.');
  if(topErr['Cities & Rivers']||topErr['SE Asian Cities & Rivers']||topErr['European Cities & Rivers'])lines.push('City-river pairs are high-yield. Berlin=Spree, Bangkok=Chao Phraya, Hanoi=Red River, Vienna=Danube.');
  if(topErr['Ocean Trenches'])lines.push('Trenches: Aleutian=N.Pacific, Mariana=W.Pacific, Sunda=Indian Ocean, S.Sandwich=S.Atlantic.');
  if(topErr['Climate Zones'])lines.push('Mediterranean climate: hot dry summers + mild moist winters. Found near Med Sea, California, Chile, SW Australia.');
  if(topErr['River Courses'])lines.push('Mekong runs through China, Myanmar, Laos, Thailand, Cambodia, Vietnam — NOT Malaysia.');

  ranked.slice(0,3).forEach(([t,c])=>lines.push(`Weak area → ${t}: ${c} error${c>1?'s':''}. Prioritise in next revision.`));

  const ib=document.getElementById('insBody');
  ib.innerHTML=lines.map(l=>`<div class="ins-line">${l}</div>`).join('');
  if(ranked.length)
    ib.innerHTML+=`<div class="weak-tags">${ranked.map(([t])=>`<span class="wt">${t}</span>`).join('')}</div>`;
}

function setTab(f,btn){
  document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));
  btn.classList.add('on');renderRev(f);
}
function renderRev(f){
  const rl=document.getElementById('revList');let html='';
  Q.forEach((q,i)=>{
    const ua=S.ans[i];
    const isSk=S.skp[i]||ua===null;
    const isOk=!isSk&&ua===q.ans;
    const isWr=!isSk&&!isOk;
    if(f==='correct'&&!isOk)return;
    if(f==='wrong'&&!isWr)return;
    if(f==='skipped'&&!isSk)return;
    const rc=isOk?'rc':isWr?'rw':'rs';
    const lbl=isOk?'✓ Correct':isWr?'✗ Wrong':'— Skipped';
    const uaTxt=isSk?'Not answered':L[ua]+') '+q.opts[ua];
    const caTxt=L[q.ans]+') '+q.opts[q.ans];
    const mHtml=q.mapImg?`<img class="rv-map" src="${q.mapImg}" alt="Map" loading="lazy" onload="this.style.opacity='1'" style="opacity:0;transition:opacity .3s" onerror="this.style.display='none'">`:'';
    html+=`<div class="rev-card ${rc}">
      <div class="rev-top">
        <span class="rv-n">Q${i+1}</span>
        <span class="rv-yr">${q.yr}</span>
        <span class="rv-badge ${rc}">${lbl}</span>
        <span class="rv-top2">${q.topic}</span>
      </div>
      <div class="rv-q">${q.text.replace(/</g,'&lt;')}</div>
      ${mHtml}
      <div class="rv-row"><span class="rv-lbl">Your answer:</span><span class="rv-val ${isSk?'':isOk?'good':'bad'}">${uaTxt}</span></div>
      <div class="rv-row"><span class="rv-lbl">Correct answer:</span><span class="rv-val good">${caTxt}</span></div>
      ${q.exp?`<div class="rv-exp"><strong>Explanation:</strong> ${q.exp}</div>`:''}
    </div>`;
  });
  if(!html)html='<p style="color:var(--ink3);text-align:center;padding:2rem;font-size:.85rem">No questions in this category.</p>';
  rl.innerHTML=html;
}

function save(){
  localStorage.setItem('geomind_v1',JSON.stringify({
    cur:S.cur,ans:S.ans,skp:S.skp,start:S.start,tLeft:S.tLeft,done:S.done
  }));
}
function restartQuiz(){
  if(!confirm('Restart? All progress will be erased.'))return;
  clearInterval(S.tInt);localStorage.removeItem('geomind_v1');
  S={cur:0,ans:new Array(34).fill(null),skp:new Array(34).fill(false),start:null,tLeft:25*60,tInt:null,done:false};
  show('start');
}
</script>
