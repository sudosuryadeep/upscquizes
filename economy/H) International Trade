   exp:'Middle Eastern arid/semi-arid countries (UAE, Saudi Arabia, Kuwait, Bahrain, etc.) export to India primarily: Fruits (dates, fresh fruits) and petroleum products — but among the given options, "Fruits and palm oil" is the closest match. The Middle East exports petroleum (not listed as option), dates and fruits, and some minerals. Palm oil comes from Southeast Asia, but among the available choices, option (b) is the most relevant — fruits from Middle East and palm oil are part of India\'s agricultural imports. The answer key indicates (b).'},

  {id:23,yr:'1996',topic:'Import Rankings 1994-95',
   text:'Consider the following items imported by India (as per 1994-95 figures). Arrange in DECREASING order of value:\nI. Capital goods  II. Petroleum  III. Pearls & precious stones  IV. Chemicals  V. Iron & Steel\n\nThe correct sequence is:',
   opts:['I, II, III, IV, V','I, II, IV, III, V','II, I, III, IV, V','II, I, IV, V, III'],
   ans:3,
   exp:'Based on 1994-95 import data: Petroleum/POL (Petroleum, Oil & Lubricants) was India\'s largest import (II). Capital goods were second (I). Chemicals ranked higher than precious stones in the mid-1990s (IV before III). Iron & Steel came last among these (V and III). The correct decreasing order was: II (Petroleum) → I (Capital Goods) → IV (Chemicals) → V (Iron & Steel) → III (Pearls & Precious Stones), giving the sequence II, I, IV, V, III — option (d).'},

  {id:24,yr:'1995',topic:'EXIM Policy Duration',
   text:'The new EXIM Policy announced in 1992 was for a period of: [1995]',
   opts:['3 years','4 years','7 years','5 years'],
   ans:3,
   exp:'The new EXIM Policy announced in April 1992 (as part of India\'s post-liberalisation economic reforms) was formulated for a period of 5 years (1992-1997). This replaced the earlier practice of annual EXIM policies. The 5-year EXIM policy aimed to provide a stable, predictable trade environment to encourage exporters to plan their businesses over a medium-term horizon. Subsequent EXIM policies also typically covered 5-year periods.'}
];

let S={cur:0,ans:new Array(24).fill(null),skp:new Array(24).fill(false),start:null,tLeft:16*60,tInt:null,done:false};
const pad=n=>String(n).padStart(2,'0');

function startQuiz(){
  const raw=localStorage.getItem('vyapar_v1');
  if(raw){const d=JSON.parse(raw);if(!d.done&&confirm('Resume previous session?')){S={...S,...d,tInt:null};}else{localStorage.removeItem('vyapar_v1');S.start=Date.now();}}
  else{S.start=Date.now();}
  show('quiz');buildDots();renderQ();runTimer();
}
function show(id){document.querySelectorAll('.screen').forEach(s=>s.classList.remove('active'));document.getElementById(id).classList.add('active');window.scrollTo(0,0)}
function runTimer(){
  if(S.tInt)clearInterval(S.tInt);updTimer();
  S.tInt=setInterval(()=>{if(S.done){clearInterval(S.tInt);return;}S.tLeft--;updTimer();if(S.tLeft%15===0)save();if(S.tLeft<=0){clearInterval(S.tInt);alert('⏱ Time is up! Submitting…');submitQuiz();}},1000);
}
function updTimer(){const m=Math.floor(S.tLeft/60),s=S.tLeft%60;const el=document.getElementById('timerEl');el.textContent=`${pad(m)}:${pad(s)}`;el.className=S.tLeft<=180?'timer danger':'timer';}
function renderQ(){
  const i=S.cur,q=Q[i];
  document.getElementById('qCur').textContent=i+1;document.getElementById('qTot').textContent=Q.length;
  document.getElementById('qBadge').textContent='Q'+String(i+1).padStart(2,'0');
  document.getElementById('qYr').textContent=q.yr;document.getElementById('qTopic').textContent=q.topic;
  document.getElementById('qBody').textContent=q.text;
  document.getElementById('pFill').style.width=((i+1)/Q.length*100)+'%';
  const sp=document.getElementById('qStat');
  if(S.skp[i]){sp.textContent='Skipped';sp.className='qstatus qs-skp';}
  else if(S.ans[i]!==null){sp.textContent='Answered';sp.className='qstatus qs-ans';}
  else{sp.textContent='Unanswered';sp.className='qstatus qs-none';}
  const og=document.getElementById('optsGrid');og.innerHTML='';
  q.opts.forEach((o,idx)=>{const b=document.createElement('button');b.className='opt'+(S.ans[i]===idx?' sel':'');b.innerHTML=`<span class="opt-key">${L[idx]}</span><span class="opt-txt">${o}</span>`;b.onclick=()=>pick(idx);og.appendChild(b);});
  document.getElementById('btnPrev').disabled=(i===0);
  const last=(i===Q.length-1);
  document.getElementById('btnNext').style.display=last?'none':'inline-block';
  document.getElementById('btnSub').style.display=last?'inline-block':'none';
  updDots();
}
function pick(idx){if(S.done)return;S.ans[S.cur]=idx;S.skp[S.cur]=false;renderQ();save();}
function go(d){const n=S.cur+d;if(n>=0&&n<Q.length){S.cur=n;renderQ();}}
function skipQ(){S.skp[S.cur]=true;S.ans[S.cur]=null;save();if(S.cur<Q.length-1)go(1);else renderQ();}
function buildDots(){const dm=document.getElementById('dotMap');dm.innerHTML='';Q.forEach((_,i)=>{const d=document.createElement('button');d.className='dot';d.textContent=i+1;d.id=`dot${i}`;d.onclick=()=>{S.cur=i;renderQ();};dm.appendChild(d);});}
function updDots(){Q.forEach((_,i)=>{const d=document.getElementById(`dot${i}`);if(!d)return;d.className='dot';if(i===S.cur)d.classList.add('cur');else if(S.skp[i])d.classList.add('d-skp');else if(S.ans[i]!==null)d.classList.add('d-ans');});}
function showMod(){const a=S.ans.filter(x=>x!==null).length,sk=S.skp.filter(Boolean).length;document.getElementById('modTxt').textContent=`Answered: ${a}  ·  Skipped: ${sk}  ·  Unanswered: ${Q.length-a-sk}\n\nOnce submitted, answers cannot be changed.`;document.getElementById('modOv').classList.add('on');}
function closeMod(){document.getElementById('modOv').classList.remove('on');}
function submitQuiz(){
  closeMod();clearInterval(S.tInt);S.done=true;
  const used=(16*60)-S.tLeft;let cor=0,wr=0,sk=0;
  Q.forEach((q,i)=>{if(S.skp[i]||S.ans[i]===null)sk++;else if(S.ans[i]===q.ans)cor++;else wr++;});
  const attempted=cor+wr,pct=Math.round(cor/Q.length*100),acc=attempted?Math.round(cor/attempted*100):0,avg=Math.round(used/Q.length);
  let grade,ringColor;
  if(pct>=90){grade='◆ Exceptional';ringColor='#10b981';}else if(pct>=75){grade='◆ Excellent';ringColor='#00c2a8';}else if(pct>=60){grade='◆ Good';ringColor='#3b9eff';}else if(pct>=45){grade='◆ Average';ringColor='#f5a623';}else{grade='◆ Keep Revising';ringColor='#f43f5e';}
  const arc=document.getElementById('ringArc');arc.style.stroke=ringColor;setTimeout(()=>{arc.style.strokeDashoffset=345.58*(1-pct/100);},100);
  document.getElementById('rScore').textContent=cor;document.getElementById('rScore').style.color=ringColor;
  const gp=document.getElementById('rGrade');gp.textContent=grade;gp.style.cssText=`background:${ringColor}18;color:${ringColor};border:1px solid ${ringColor}38;`;
  if(pct>=75)document.getElementById('rTitle').textContent='Outstanding Performance!';else if(pct>=50)document.getElementById('rTitle').textContent='Solid Attempt!';else document.getElementById('rTitle').textContent='More Revision Needed';
  document.getElementById('rSub').textContent=`${pct}% accuracy · ${cor} correct out of ${Q.length} questions`;
  document.getElementById('rPct').textContent=`Attempt Accuracy: ${acc}% (of ${attempted} attempted)`;
  document.getElementById('stC').textContent=cor;document.getElementById('stW').textContent=wr;document.getElementById('stS').textContent=sk;
  document.getElementById('stAcc').textContent=acc+'%';document.getElementById('stTime').textContent=fmtT(used);document.getElementById('stAvg').textContent=avg+'s';
  buildInsights(cor,wr,sk,pct,acc);renderRev('all');localStorage.removeItem('vyapar_v1');show('results');
}
function fmtT(s){return `${Math.floor(s/60)}m ${pad(s%60)}s`;}
function buildInsights(cor,wr,sk,pct,acc){
  const topErr={};Q.forEach((q,i)=>{if(!S.skp[i]&&S.ans[i]!==null&&S.ans[i]!==q.ans)topErr[q.topic]=(topErr[q.topic]||0)+1;});
  const ranked=Object.entries(topErr).sort((a,b)=>b[1]-a[1]);const lines=[];
  if(pct>=90)lines.push('<strong>Exceptional!</strong> Expert-level command over India\'s trade statistics and policy. Fully exam-ready.');
  else if(pct>=75)lines.push('<strong>Strong performance!</strong> Revise assertion-reason questions and check recent trade statistics.');
  else if(pct>=50)lines.push('Good base. Focus on Assertion-Reason logic, current account deficit concepts, and top import categories.');
  else lines.push('Revise India Year Book chapters on Foreign Trade and Economic Survey\'s trade section. These are data-heavy questions.');
  if(sk>4)lines.push(`<strong>${sk} skipped</strong> — Use elimination: if you know what India\'s top import is (petroleum), you can often rule out other options.`);
  if(topErr['Agricultural Imports']||topErr['Edible Oil Imports'])lines.push('<strong>Agri Imports:</strong> Vegetable oils (palm oil) = largest agri import by value. India imports 14-16 MT/year (~60% of requirement) mainly from Indonesia & Malaysia.');
  if(topErr['Bilateral Trade – South Asia'])lines.push('<strong>South Asia Trade:</strong> Bangladesh = largest trading partner in South Asia (not Nepal). Key India-Bangladesh trade: textiles, machinery, cotton.');
  if(topErr['International Trade – India'])lines.push('<strong>India Trade fundamentals:</strong> Always has merchandise DEFICIT. Services SURPLUS (IT/BPO). Current Account = usually deficit. India\'s world export share ~1.8-2%.');
  if(topErr['WTO – TRIMS'])lines.push('<strong>TRIMs:</strong> Applies to GOODS only (not services). Prohibits local content requirements, trade balancing. Does NOT regulate FDI itself.');
  if(topErr['Software & IT Exports']||topErr['IT & Software Exports'])lines.push('<strong>IT/Software:</strong> India strong in SOFTWARE exports, NOT hardware. USA is the primary destination. By 2003, IT services (~28% growth even during dot-com bust).');
  ranked.slice(0,3).forEach(([t,c])=>lines.push(`<strong>Weak area → ${t}:</strong> ${c} wrong. Prioritise in next revision.`));
  const ib=document.getElementById('insBody');ib.innerHTML=lines.map(l=>`<div class="ins-line">${l}</div>`).join('');
  if(ranked.length)ib.innerHTML+=`<div class="weak-wrap">${ranked.map(([t])=>`<span class="wchip">${t}</span>`).join('')}</div>`;
}
function setTab(f,btn){document.querySelectorAll('.tab').forEach(b=>b.classList.remove('on'));btn.classList.add('on');renderRev(f);}
function renderRev(f){
  const rl=document.getElementById('revList');let html='';
  Q.forEach((q,i)=>{
    const ua=S.ans[i],isSk=S.skp[i]||ua===null,isOk=!isSk&&ua===q.ans,isWr=!isSk&&!isOk;
    if(f==='correct'&&!isOk)return;if(f==='wrong'&&!isWr)return;if(f==='skipped'&&!isSk)return;
    const rc=isOk?'rc':isWr?'rw':'rs',lbl=isOk?'✓ Correct':isWr?'✗ Wrong':'— Skipped';
    const uaTxt=isSk?'Not answered / Skipped':`${L[ua]}) ${q.opts[ua]}`,caTxt=`${L[q.ans]}) ${q.opts[q.ans]}`;
    html+=`<div class="rev-card ${rc}"><div class="rev-top"><span class="rv-n">Q${i+1}</span><span class="rv-yr">${q.yr}</span><span class="rv-badge ${rc}">${lbl}</span><span class="rv-topic">${q.topic}</span></div><div class="rv-q">${q.text.replace(/</g,'&lt;')}</div><div class="rv-row"><span class="rv-lbl">Your answer:</span><span class="rv-val ${isSk?'':isOk?'good':'bad'}">${uaTxt}</span></div><div class="rv-row"><span class="rv-lbl">Correct answer:</span><span class="rv-val good">${caTxt}</span></div>${q.exp?`<div class="rv-exp"><strong>Explanation:</strong> ${q.exp}</div>`:''}</div>`;
  });
  if(!html)html='<p style="color:var(--txt2);text-align:center;padding:2rem;font-size:.85rem;font-family:\'DM Mono\',monospace">// No questions in this category.</p>';
  rl.innerHTML=html;
}
function save(){localStorage.setItem('vyapar_v1',JSON.stringify({cur:S.cur,ans:S.ans,skp:S.skp,start:S.start,tLeft:S.tLeft,done:S.done}));}
function restartQuiz(){if(!confirm('Restart? All progress will be lost.'))return;clearInterval(S.tInt);localStorage.removeItem('vyapar_v1');S={cur:0,ans:new Array(24).fill(null),skp:new Array(24).fill(false),start:null,tLeft:16*60,tInt:null,done:false};show('start');}
</script>
