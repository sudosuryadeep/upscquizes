<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Vyapar · India Trade & Exports Quiz</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;0,900;1,400&family=DM+Sans:ital,wght@0,300;0,400;0,500;0,600;1,400&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#060a0f;--bg2:#090e17;--bg3:#0e1520;
  --surface:#111c28;--surface2:#172233;
  --teal:#00c2a8;--teal2:#00a88f;--teal3:#4dffd9;
  --teal-dim:rgba(0,194,168,.1);
  --gold:#f5a623;--gold2:#ffc96b;--gold3:#ffe4b0;
  --blue:#3b9eff;--blue2:#7bc4ff;
  --correct:#10b981;--wrong:#ef4444;--skip:#f59e0b;
  --txt:#e4f0ff;--txt2:#6a849e;--txt3:#a8c0d8;
  --border:rgba(255,255,255,.06);--border2:rgba(0,194,168,.18);
  --r:12px;--r2:18px;--r3:24px;
}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:var(--bg);color:var(--txt);min-height:100vh;overflow-x:hidden}

body::before{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background-image:
    linear-gradient(rgba(0,194,168,.025) 1px,transparent 1px),
    linear-gradient(90deg,rgba(0,194,168,.025) 1px,transparent 1px);
  background-size:48px 48px;
}
body::after{
  content:'';position:fixed;inset:0;z-index:0;pointer-events:none;
  background:
    radial-gradient(ellipse 55% 45% at 15% 15%,rgba(0,194,168,.1) 0%,transparent 65%),
    radial-gradient(ellipse 50% 55% at 85% 85%,rgba(245,166,35,.07) 0%,transparent 60%),
    radial-gradient(ellipse 35% 35% at 60% 30%,rgba(59,158,255,.05) 0%,transparent 70%);
}

.orbs{position:fixed;inset:0;z-index:0;pointer-events:none;overflow:hidden}
.orb{position:absolute;border-radius:50%;filter:blur(90px);animation:orbF ease-in-out infinite}
.o1{width:380px;height:380px;top:-80px;left:-80px;background:rgba(0,194,168,.07);animation-duration:20s}
.o2{width:280px;height:280px;bottom:-60px;right:-60px;background:rgba(245,166,35,.06);animation-duration:25s;animation-delay:-9s}
.o3{width:200px;height:200px;top:55%;left:65%;background:rgba(59,158,255,.05);animation-duration:17s;animation-delay:-4s}
@keyframes orbF{0%,100%{transform:translate(0,0) scale(1)}40%{transform:translate(25px,-35px) scale(1.04)}70%{transform:translate(-18px,18px) scale(.97)}}

.screen{display:none;position:relative;z-index:1;min-height:100vh}
.screen.active{display:flex}

/* ── START ── */
#start{flex-direction:column;align-items:center;justify-content:center;padding:2.5rem 1.5rem;text-align:center}

.hero-icon{position:relative;width:108px;height:108px;margin:0 auto 2.2rem}
.ir{position:absolute;inset:0;border-radius:50%;border:1.5px solid var(--border2);animation:rp 3s ease-in-out infinite}
.ir2{position:absolute;inset:-13px;border-radius:50%;border:1px solid rgba(0,194,168,.1);animation:rp 3s ease-in-out infinite .6s}
.ir3{position:absolute;inset:-25px;border-radius:50%;border:1px solid rgba(0,194,168,.05);animation:rp 3s ease-in-out infinite 1.2s}
@keyframes rp{0%,100%{transform:scale(1);opacity:.9}50%{transform:scale(1.12);opacity:.2}}
.icore{position:absolute;inset:0;border-radius:50%;background:linear-gradient(135deg,rgba(0,194,168,.18),rgba(245,166,35,.1));border:1.5px solid var(--border2);display:flex;align-items:center;justify-content:center;font-size:2.8rem;backdrop-filter:blur(12px)}

.eyebrow{font-family:'DM Mono',monospace;font-size:.58rem;letter-spacing:.3em;text-transform:uppercase;color:var(--teal);margin-bottom:1.2rem;opacity:0;animation:fU .5s .2s ease forwards;display:flex;align-items:center;gap:.6rem}
.eyebrow::before,.eyebrow::after{content:'';display:block;width:28px;height:1px;background:var(--teal);opacity:.4}

.hero-title{font-family:'Playfair Display',serif;font-size:clamp(2.5rem,9vw,5rem);font-weight:900;line-height:.95;margin-bottom:.7rem;opacity:0;animation:fU .6s .35s ease forwards}
.ht1{display:block;background:linear-gradient(135deg,var(--teal3),var(--teal),var(--gold));-webkit-background-clip:text;-webkit-text-fill-color:transparent;background-clip:text}
.ht2{display:block;font-size:.38em;font-weight:400;font-style:italic;color:var(--txt2);letter-spacing:.04em;-webkit-text-fill-color:var(--txt2);margin-top:.4rem}

.hero-sub{font-size:.875rem;color:var(--txt2);max-width:440px;margin:1.5rem auto 2.5rem;line-height:2;font-weight:300;opacity:0;animation:fU .5s .5s ease forwards}

.info-strip{display:grid;grid-template-columns:repeat(3,1fr);margin-bottom:2.5rem;border:1px solid var(--border2);border-radius:var(--r2);overflow:hidden;background:rgba(0,194,168,.03);backdrop-filter:blur(16px);opacity:0;animation:fU .5s .65s ease forwards;max-width:500px;width:100%}
.info-item{padding:1.2rem 1rem;border-right:1px solid var(--border2);display:flex;flex-direction:column;align-items:center;gap:.3rem}
.info-item:last-child{border-right:none}
.info-ic{font-size:1.3rem}
.info-v{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--teal)}
.info-l{font-size:.58rem;text-transform:uppercase;letter-spacing:.12em;color:var(--txt2)}

.topic-row{display:flex;flex-wrap:wrap;gap:.4rem;justify-content:center;max-width:520px;margin:0 auto 2.8rem;opacity:0;animation:fU .5s .8s ease forwards}
.tp{font-family:'DM Mono',monospace;font-size:.62rem;padding:.3rem .9rem;border-radius:50px;border:1px solid rgba(0,194,168,.18);background:rgba(0,194,168,.05);color:var(--teal);font-weight:500;letter-spacing:.04em;transition:.2s}
.tp:hover{background:rgba(0,194,168,.12)}

.start-btn{position:relative;overflow:hidden;padding:1.05rem 3.5rem;border:none;border-radius:50px;font-family:'DM Sans',sans-serif;font-size:.95rem;font-weight:600;letter-spacing:.06em;cursor:pointer;transition:all .3s;background:linear-gradient(135deg,var(--teal2),#007a68,var(--gold));color:#fff;box-shadow:0 8px 32px rgba(0,194,168,.28),0 0 0 1px rgba(0,194,168,.15),inset 0 1px 0 rgba(255,255,255,.15);opacity:0;animation:fU .5s .95s ease forwards}
.start-btn::after{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(255,255,255,.12),transparent 50%);opacity:0;transition:.3s}
.start-btn:hover::after{opacity:1}
.start-btn:hover{transform:translateY(-4px);box-shadow:0 20px 50px rgba(0,194,168,.42)}
.start-btn span{position:relative;z-index:1;display:flex;align-items:center;gap:.6rem}
.save-note{margin-top:1.2rem;font-size:.7rem;color:var(--txt2);opacity:0;animation:fU .4s 1.1s ease forwards;font-family:'DM Mono',monospace;letter-spacing:.05em}
@keyframes fU{from{opacity:0;transform:translateY(18px)}to{opacity:1;transform:translateY(0)}}

/* ── QUIZ ── */
#quiz{flex-direction:column;align-items:center;padding:1.2rem 1rem 2rem;gap:.9rem}
.quiz-wrap{max-width:820px;width:100%;display:flex;flex-direction:column;gap:.9rem}

.topbar{display:flex;align-items:center;justify-content:space-between;gap:.8rem;padding:.85rem 1.2rem;background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:var(--r2);backdrop-filter:blur(14px)}
.qcount{font-family:'DM Mono',monospace;font-size:.78rem;color:var(--txt2);letter-spacing:.05em}
.qcount em{color:var(--teal);font-style:normal;font-weight:600}
.timer{font-family:'DM Mono',monospace;font-weight:500;font-size:.9rem;padding:.4rem 1.1rem;border-radius:50px;background:rgba(0,194,168,.08);border:1px solid rgba(0,194,168,.25);color:var(--teal);transition:.3s;letter-spacing:.08em}
.timer.danger{background:rgba(244,63,94,.12);border-color:rgba(244,63,94,.4);color:#fb7185;animation:bl .65s infinite}
@keyframes bl{0%,100%{opacity:1}50%{opacity:.35}}
.submit-early{font-size:.72rem;padding:.38rem .9rem;border-radius:50px;background:transparent;border:1px solid var(--border);color:var(--txt2);cursor:pointer;transition:.2s;font-family:'DM Sans',sans-serif;font-weight:500}
.submit-early:hover{border-color:var(--teal);color:var(--teal)}

.pbar{height:2px;background:rgba(255,255,255,.05);border-radius:10px;overflow:hidden;position:relative}
.pfill{height:100%;background:linear-gradient(90deg,var(--teal2),var(--gold),var(--teal3));border-radius:10px;transition:width .6s cubic-bezier(.4,0,.2,1);box-shadow:0 0 16px rgba(0,194,168,.55);position:relative}
.pfill::after{content:'';position:absolute;right:0;top:50%;transform:translateY(-50%);width:6px;height:6px;border-radius:50%;background:var(--teal3);box-shadow:0 0 8px var(--teal)}

.qcard{background:linear-gradient(145deg,rgba(14,21,32,.97),rgba(6,10,15,.98));border:1px solid var(--border);border-radius:var(--r3);padding:2.2rem;box-shadow:0 12px 60px rgba(0,0,0,.6),inset 0 1px 0 rgba(255,255,255,.04);animation:sI .4s cubic-bezier(.34,1.56,.64,1);position:relative;overflow:hidden}
.qcard::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,194,168,.3),transparent)}
@keyframes sI{from{opacity:0;transform:translateY(22px) scale(.97)}to{opacity:1;transform:none}}

.qmeta{display:flex;align-items:center;gap:.45rem;margin-bottom:1.5rem;flex-wrap:wrap}
.qnum-badge{font-family:'DM Mono',monospace;font-size:.62rem;font-weight:500;letter-spacing:.08em;padding:.3rem .85rem;border-radius:50px;background:linear-gradient(135deg,rgba(0,194,168,.2),rgba(245,166,35,.12));border:1px solid rgba(0,194,168,.3);color:var(--teal3)}
.qyr{font-size:.62rem;color:var(--gold2);background:rgba(245,166,35,.08);padding:.28rem .72rem;border-radius:50px;border:1px solid rgba(245,166,35,.2);font-family:'DM Mono',monospace}
.qtopic{font-size:.62rem;color:var(--blue2);background:rgba(59,158,255,.08);border:1px solid rgba(59,158,255,.18);padding:.28rem .72rem;border-radius:50px}
.qstatus{margin-left:auto;font-size:.6rem;font-weight:600;padding:.28rem .75rem;border-radius:50px;font-family:'DM Mono',monospace}
.qs-none{background:rgba(255,255,255,.04);color:var(--txt2);border:1px solid var(--border)}
.qs-ans{background:rgba(16,185,129,.1);color:#34d399;border:1px solid rgba(16,185,129,.25)}
.qs-skp{background:rgba(245,158,11,.08);color:var(--gold2);border:1px solid rgba(245,158,11,.22)}

.qtext{font-size:.92rem;line-height:2;color:var(--txt3);margin-bottom:1.6rem;white-space:pre-wrap}

.opts{display:flex;flex-direction:column;gap:.55rem}
.opt{display:flex;align-items:flex-start;gap:.9rem;padding:.9rem 1.15rem;background:rgba(255,255,255,.018);border:1.5px solid rgba(255,255,255,.065);border-radius:12px;cursor:pointer;transition:all .2s;text-align:left;width:100%;color:var(--txt3);font-family:'DM Sans',sans-serif;font-size:.875rem;line-height:1.65;position:relative;overflow:hidden}
.opt::before{content:'';position:absolute;inset:0;background:linear-gradient(135deg,rgba(0,194,168,.06),transparent);opacity:0;transition:.2s}
.opt:hover:not(.sel){border-color:rgba(0,194,168,.35);transform:translateX(5px);background:rgba(0,194,168,.04)}
.opt:hover:not(.sel)::before{opacity:1}
.opt.sel{background:rgba(0,194,168,.07);border-color:var(--teal)}
.opt.sel::before{opacity:1}
.opt-key{min-width:30px;height:30px;border-radius:8px;background:rgba(0,194,168,.08);border:1px solid rgba(0,194,168,.18);display:flex;align-items:center;justify-content:center;font-family:'DM Mono',monospace;font-size:.68rem;font-weight:500;color:var(--teal);flex-shrink:0;transition:.2s;position:relative;z-index:1}
.opt.sel .opt-key{background:linear-gradient(135deg,var(--teal),var(--gold));color:#fff;border-color:transparent;box-shadow:0 2px 12px rgba(0,194,168,.4)}
.opt-txt{position:relative;z-index:1;color:var(--txt)}

.qnav{display:flex;justify-content:space-between;margin-top:1.6rem;gap:.6rem;flex-wrap:wrap}
.btn{padding:.65rem 1.4rem;border:none;border-radius:50px;font-family:'DM Sans',sans-serif;font-size:.82rem;font-weight:600;cursor:pointer;transition:all .2s;letter-spacing:.02em}
.btn:disabled{opacity:.25;cursor:not-allowed}
.btn-ghost{background:rgba(255,255,255,.045);border:1px solid var(--border);color:var(--txt2)}
.btn-ghost:hover:not(:disabled){background:rgba(255,255,255,.09);color:var(--txt)}
.btn-skip{background:rgba(245,158,11,.08);border:1px solid rgba(245,158,11,.22);color:var(--gold2)}
.btn-skip:hover{background:rgba(245,158,11,.16)}
.btn-primary{background:linear-gradient(135deg,var(--teal2),#006a58);color:#fff;box-shadow:0 4px 18px rgba(0,194,168,.28)}
.btn-primary:hover{transform:translateY(-2px);box-shadow:0 8px 28px rgba(0,194,168,.45)}
.btn-submit{background:linear-gradient(135deg,var(--gold),#c07800);color:#fff;box-shadow:0 4px 14px rgba(245,166,35,.3)}
.btn-submit:hover{transform:translateY(-2px);box-shadow:0 8px 24px rgba(245,166,35,.5)}

.dotrow{display:flex;flex-wrap:wrap;gap:.28rem;max-width:820px;width:100%}
.dot{width:30px;height:30px;border-radius:8px;border:none;font-size:.62rem;font-weight:600;cursor:pointer;transition:.15s;font-family:'DM Mono',monospace;background:rgba(255,255,255,.035);border:1px solid var(--border);color:var(--txt2)}
.dot:hover{border-color:var(--teal);color:var(--teal);background:rgba(0,194,168,.05)}
.dot.cur{background:linear-gradient(135deg,var(--teal2),var(--gold));color:#fff;border-color:transparent;box-shadow:0 2px 14px rgba(0,194,168,.45)}
.dot.d-ans{background:rgba(16,185,129,.12);color:#34d399;border-color:rgba(16,185,129,.3)}
.dot.d-skp{background:rgba(245,158,11,.1);color:var(--gold2);border-color:rgba(245,158,11,.25)}

.overlay{display:none;position:fixed;inset:0;background:rgba(3,5,12,.88);backdrop-filter:blur(20px);z-index:500;align-items:center;justify-content:center;padding:1rem}
.overlay.on{display:flex}
.modal{background:linear-gradient(145deg,var(--surface),var(--bg2));border:1px solid rgba(0,194,168,.25);border-radius:var(--r3);padding:2.8rem;max-width:420px;width:100%;text-align:center;box-shadow:0 40px 100px rgba(0,0,0,.8),0 0 50px rgba(0,194,168,.07);animation:mP .3s cubic-bezier(.34,1.56,.64,1)}
@keyframes mP{from{transform:scale(.86);opacity:0}to{transform:scale(1);opacity:1}}
.modal-icon{font-size:3rem;margin-bottom:1rem;display:block}
.modal h3{font-family:'Playfair Display',serif;font-size:1.3rem;font-weight:700;color:var(--txt);margin-bottom:.7rem}
.modal p{color:var(--txt2);font-size:.84rem;line-height:1.9;margin-bottom:2rem;white-space:pre-wrap;font-family:'DM Mono',monospace}
.modal-btns{display:flex;gap:.7rem;justify-content:center}

/* ── RESULTS ── */
#results{flex-direction:column;align-items:center;padding:2rem 1rem 3rem}
.res-wrap{max-width:880px;width:100%}

.res-hero{background:linear-gradient(145deg,rgba(14,21,32,.98),rgba(6,10,15,.99));border:1px solid var(--border2);border-radius:var(--r3);padding:3rem 2rem;text-align:center;margin-bottom:1.2rem;position:relative;overflow:hidden}
.res-hero::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,var(--teal),transparent)}
.res-hero::after{content:'';position:absolute;inset:0;pointer-events:none;background:radial-gradient(ellipse 60% 50% at 50% 100%,rgba(0,194,168,.06),transparent),radial-gradient(ellipse 40% 60% at 10% 10%,rgba(245,166,35,.06),transparent)}

.score-display{position:relative;width:170px;height:170px;margin:0 auto 1.8rem}
.score-display svg{width:100%;height:100%;transform:rotate(-90deg)}
.ring-bg{fill:none;stroke:rgba(255,255,255,.04);stroke-width:7}
.ring-fill{fill:none;stroke-width:7;stroke-linecap:round;transition:stroke-dashoffset 1.8s cubic-bezier(.4,0,.2,1)}
.score-inner{position:absolute;inset:0;display:flex;flex-direction:column;align-items:center;justify-content:center}
.score-num{font-family:'Playfair Display',serif;font-size:3rem;font-weight:900;line-height:1;color:var(--teal3)}
.score-denom{font-size:.72rem;color:var(--txt2);font-family:'DM Mono',monospace}

.res-title{font-family:'Playfair Display',serif;font-size:clamp(1.4rem,4vw,2.2rem);font-weight:900;font-style:italic;color:var(--txt);margin-bottom:.4rem;position:relative;z-index:1}
.res-sub{color:var(--txt2);font-size:.84rem;margin-bottom:1.5rem;position:relative;z-index:1}
.grade-chip{display:inline-block;font-family:'DM Mono',monospace;font-size:.82rem;font-weight:500;padding:.45rem 1.6rem;border-radius:50px;margin-bottom:.5rem;position:relative;z-index:1;letter-spacing:.04em}
.pct-tag{color:var(--txt2);font-size:.82rem;position:relative;z-index:1;font-family:'DM Mono',monospace}

.stats-grid{display:grid;grid-template-columns:repeat(3,1fr);gap:.8rem;margin-bottom:1.2rem}
@media(max-width:500px){.stats-grid{grid-template-columns:repeat(2,1fr)}}
.stat-box{background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:16px;padding:1.2rem .9rem;text-align:center;backdrop-filter:blur(10px);transition:.2s;position:relative;overflow:hidden}
.stat-box::before{content:'';position:absolute;top:0;left:0;right:0;height:1px;background:linear-gradient(90deg,transparent,rgba(0,194,168,.2),transparent)}
.stat-box:hover{transform:translateY(-3px);border-color:rgba(0,194,168,.2)}
.stat-ico{font-size:1.4rem;margin-bottom:.4rem}
.stat-val{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;margin-bottom:.2rem}
.stat-lbl{font-size:.58rem;text-transform:uppercase;letter-spacing:.1em;color:var(--txt2);font-family:'DM Mono',monospace}

.insights{background:rgba(0,194,168,.03);border:1px solid rgba(0,194,168,.15);border-radius:var(--r2);padding:1.6rem;margin-bottom:1.2rem;backdrop-filter:blur(10px)}
.ins-hd{font-family:'DM Mono',monospace;font-size:.78rem;font-weight:500;color:var(--teal);margin-bottom:1.1rem;display:flex;align-items:center;gap:.5rem;letter-spacing:.08em}
.ins-line{font-size:.8rem;color:var(--txt2);margin-bottom:.6rem;line-height:1.85;padding-left:.9rem;border-left:2px solid rgba(0,194,168,.2)}
.ins-line strong{color:var(--teal)}
.weak-wrap{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.9rem}
.wchip{font-size:.64rem;font-weight:500;padding:.22rem .68rem;border-radius:50px;background:rgba(244,63,94,.08);color:#fda4af;border:1px solid rgba(244,63,94,.18);font-family:'DM Mono',monospace}

.tabs{display:flex;gap:.22rem;background:rgba(255,255,255,.025);border:1px solid var(--border);border-radius:12px;padding:.28rem;margin-bottom:.9rem;backdrop-filter:blur(10px)}
.tab{flex:1;padding:.48rem;border:none;border-radius:9px;background:transparent;font-family:'DM Sans',sans-serif;font-size:.72rem;font-weight:500;cursor:pointer;color:var(--txt2);transition:.2s}
.tab.on{background:linear-gradient(135deg,rgba(0,194,168,.18),rgba(245,166,35,.1));color:var(--txt);border:1px solid rgba(0,194,168,.2)}

.rev-card{background:rgba(255,255,255,.02);border:1px solid var(--border);border-radius:16px;padding:1.4rem;margin-bottom:.7rem;border-left:3px solid transparent;backdrop-filter:blur(8px);animation:sI .3s ease;transition:transform .2s}
.rev-card:hover{transform:translateX(4px)}
.rev-card.rc{border-left-color:var(--correct)}
.rev-card.rw{border-left-color:var(--wrong)}
.rev-card.rs{border-left-color:var(--skip)}
.rev-top{display:flex;flex-wrap:wrap;align-items:center;gap:.4rem;margin-bottom:.8rem}
.rv-n{font-family:'DM Mono',monospace;font-size:.62rem;padding:.22rem .58rem;border-radius:50px;background:rgba(255,255,255,.05);color:var(--txt2)}
.rv-yr{font-size:.62rem;color:var(--gold2);background:rgba(245,166,35,.07);padding:.22rem .58rem;border-radius:50px;border:1px solid rgba(245,166,35,.18);font-family:'DM Mono',monospace}
.rv-badge{font-size:.62rem;font-weight:600;padding:.22rem .62rem;border-radius:50px;font-family:'DM Mono',monospace}
.rv-badge.rc{background:rgba(16,185,129,.1);color:#34d399}
.rv-badge.rw{background:rgba(239,68,68,.1);color:#f87171}
.rv-badge.rs{background:rgba(245,158,11,.08);color:var(--gold2)}
.rv-topic{margin-left:auto;font-size:.62rem;color:var(--blue2);background:rgba(59,158,255,.07);padding:.22rem .58rem;border-radius:50px}
.rv-q{font-size:.82rem;color:var(--txt2);margin-bottom:.9rem;line-height:1.8;white-space:pre-wrap}
.rv-row{display:flex;gap:.5rem;font-size:.78rem;margin-bottom:.3rem;align-items:flex-start}
.rv-lbl{font-weight:600;min-width:116px;color:var(--txt2);flex-shrink:0;font-size:.74rem;font-family:'DM Mono',monospace}
.rv-val{color:var(--txt)}
.rv-val.good{color:#34d399}
.rv-val.bad{color:#f87171}
