<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>GeoMind · UPSC World Geography</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,700;1,400&family=DM+Sans:wght@300;400;500&family=DM+Mono:wght@400;500&display=swap" rel="stylesheet">
<style>
*{margin:0;padding:0;box-sizing:border-box}
:root{
  --bg:#f5f0e8;
  --bg2:#ede8df;
  --ink:#1a1612;
  --ink2:#4a4540;
  --ink3:#8a837a;
  --accent:#c84b2f;
  --accent2:#e8855a;
  --gold:#b8860b;
  --correct:#2d6a4f;
  --wrong:#c84b2f;
  --card:#ffffff;
  --border:#d4cfc8;
  --r:12px;
}
html{scroll-behavior:smooth}
body{
  font-family:'DM Sans',sans-serif;
  background:var(--bg);
  color:var(--ink);
  min-height:100vh;
  overflow-x:hidden;
}

/* grain texture */
body::before{
  content:'';position:fixed;inset:0;z-index:0;
  background-image:url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.035'/%3E%3C/svg%3E");
  pointer-events:none;opacity:.5;
}

.screen{display:none;position:relative;z-index:1;min-height:100vh}
.screen.active{display:flex}

/* ── START ── */
#start{
  flex-direction:column;align-items:center;justify-content:center;
  padding:2rem;text-align:center;gap:0;
}

.s-eyebrow{
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.2em;
  text-transform:uppercase;color:var(--ink3);margin-bottom:2rem;
  display:flex;align-items:center;gap:.8rem;
}
.s-eyebrow::before,.s-eyebrow::after{
  content:'';height:1px;width:40px;background:var(--border);
}

.s-title{
  font-family:'Playfair Display',serif;
  font-size:clamp(3rem,10vw,6.5rem);
  line-height:.95;color:var(--ink);
  margin-bottom:1.6rem;
}
.s-title em{color:var(--accent);font-style:italic}

.s-sub{
  font-size:.88rem;color:var(--ink3);
  max-width:400px;line-height:1.8;margin-bottom:3rem;
  font-weight:300;
}

.s-stats{
  display:flex;gap:0;border:1px solid var(--border);border-radius:var(--r);
  overflow:hidden;margin-bottom:3rem;background:var(--card);
}
.s-stat{
  padding:1.2rem 2rem;border-right:1px solid var(--border);
  display:flex;flex-direction:column;align-items:center;gap:.25rem;
}
.s-stat:last-child{border-right:none}
.s-stat-v{
  font-family:'Playfair Display',serif;font-size:1.8rem;
  font-weight:700;color:var(--ink);
}
.s-stat-l{font-size:.65rem;text-transform:uppercase;letter-spacing:.1em;color:var(--ink3)}

.s-btn{
  background:var(--ink);color:var(--bg);
  border:none;padding:1rem 3rem;border-radius:50px;
  font-family:'DM Sans',sans-serif;font-size:.9rem;font-weight:500;
  cursor:pointer;transition:all .25s;letter-spacing:.04em;
  position:relative;overflow:hidden;
}
.s-btn::before{
  content:'';position:absolute;inset:0;
  background:var(--accent);
  transform:translateX(-100%);transition:.3s cubic-bezier(.4,0,.2,1);
}
.s-btn:hover::before{transform:translateX(0)}
.s-btn span{position:relative;z-index:1}
.s-btn:hover{transform:translateY(-2px);box-shadow:0 12px 30px rgba(26,22,18,.25)}

.s-note{margin-top:1.2rem;font-size:.72rem;color:var(--ink3)}

/* ── QUIZ ── */
#quiz{
  flex-direction:column;align-items:center;
  padding:1.5rem 1rem;gap:1rem;
}
.q-shell{max-width:780px;width:100%;display:flex;flex-direction:column;gap:1rem}

/* Header strip */
.q-header{
  display:flex;align-items:center;justify-content:space-between;
  padding:0;
}
.q-counter{
  font-family:'DM Mono',monospace;font-size:.75rem;
  color:var(--ink3);letter-spacing:.05em;
}
.q-timer{
  font-family:'DM Mono',monospace;font-size:.85rem;font-weight:500;
  color:var(--ink);background:var(--card);border:1px solid var(--border);
  padding:.4rem .9rem;border-radius:50px;transition:.3s;
}
.q-timer.hot{color:var(--accent);border-color:var(--accent);animation:pulse .8s infinite}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.5}}

/* Progress bar */
.q-bar{height:2px;background:var(--border);border-radius:10px;overflow:hidden}
.q-fill{height:100%;background:var(--accent);border-radius:10px;transition:width .5s ease}

/* Card */
.q-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:16px;padding:2rem;
  box-shadow:0 2px 20px rgba(26,22,18,.06);
  animation:slideUp .35s cubic-bezier(.4,0,.2,1);
}
@keyframes slideUp{from{opacity:0;transform:translateY(10px)}to{opacity:1;transform:none}}

.q-meta{
  display:flex;align-items:center;gap:.6rem;margin-bottom:1.4rem;flex-wrap:wrap;
}
.q-num{
  font-family:'DM Mono',monospace;font-size:.65rem;letter-spacing:.1em;
  color:var(--accent);background:rgba(200,75,47,.08);
  padding:.25rem .7rem;border-radius:50px;
  border:1px solid rgba(200,75,47,.2);
}
.q-yr{
  font-family:'DM Mono',monospace;font-size:.65rem;
  color:var(--gold);background:rgba(184,134,11,.07);
  padding:.25rem .7rem;border-radius:50px;
  border:1px solid rgba(184,134,11,.2);
}
.q-topic{
  font-size:.65rem;color:var(--ink3);background:var(--bg2);
  padding:.25rem .7rem;border-radius:50px;border:1px solid var(--border);
}
.q-status-tag{
  margin-left:auto;font-size:.62rem;font-weight:500;
  padding:.25rem .7rem;border-radius:50px;
}
.qs-none{background:var(--bg2);color:var(--ink3);border:1px solid var(--border)}
.qs-ans{background:rgba(45,106,79,.1);color:var(--correct);border:1px solid rgba(45,106,79,.25)}
.qs-skp{background:rgba(184,134,11,.1);color:var(--gold);border:1px solid rgba(184,134,11,.2)}

.q-body{
  font-family:'Playfair Display',serif;
  font-size:1.05rem;line-height:1.85;
  color:var(--ink);margin-bottom:1.6rem;
  white-space:pre-wrap;
}

/* Map */
.map-area{
  margin:0 0 1.4rem;border-radius:10px;overflow:hidden;
  border:1px solid var(--border);background:var(--bg2);
}
.map-area img{
  width:100%;max-height:300px;object-fit:contain;
  display:block;background:#fff;
  opacity:0;transition:opacity .4s;
}
.map-area img.in{opacity:1}
.map-cap{
  padding:.6rem 1rem;font-size:.72rem;color:var(--ink3);
  font-style:italic;border-top:1px solid var(--border);
}

/* Options */
.opts{display:flex;flex-direction:column;gap:.55rem}
.opt{
  display:flex;align-items:flex-start;gap:.85rem;
  padding:.9rem 1.1rem;
  background:transparent;border:1.5px solid var(--border);
  border-radius:10px;cursor:pointer;transition:all .18s;
  text-align:left;width:100%;
  font-family:'DM Sans',sans-serif;font-size:.875rem;
  line-height:1.6;color:var(--ink);
}
.opt:hover:not(.sel){
  border-color:var(--accent);background:rgba(200,75,47,.04);
  transform:translateX(4px);
}
.opt.sel{
  border-color:var(--accent);background:rgba(200,75,47,.06);
}
.opt-ltr{
  min-width:26px;height:26px;border-radius:6px;
  background:var(--bg2);border:1px solid var(--border);
  display:flex;align-items:center;justify-content:center;
  font-family:'DM Mono',monospace;font-size:.7rem;font-weight:500;
  color:var(--ink3);flex-shrink:0;transition:.18s;
}
.opt.sel .opt-ltr{background:var(--accent);color:#fff;border-color:var(--accent)}

/* Nav */
.q-nav{display:flex;justify-content:space-between;margin-top:1.4rem;gap:.6rem;flex-wrap:wrap}
.btn{
  padding:.65rem 1.4rem;border:none;border-radius:50px;
  font-family:'DM Sans',sans-serif;font-size:.8rem;font-weight:500;
  cursor:pointer;transition:all .2s;letter-spacing:.02em;
}
.btn:disabled{opacity:.3;cursor:not-allowed}
.btn-outline{background:transparent;border:1.5px solid var(--border);color:var(--ink2)}
.btn-outline:hover:not(:disabled){border-color:var(--ink);background:var(--bg2)}
.btn-skip{background:rgba(184,134,11,.1);border:1px solid rgba(184,134,11,.25);color:var(--gold)}
.btn-skip:hover{background:rgba(184,134,11,.2)}
.btn-dark{background:var(--ink);color:var(--bg)}
.btn-dark:hover{background:#2d2820;transform:translateY(-2px);box-shadow:0 6px 20px rgba(26,22,18,.2)}
.btn-green{background:var(--correct);color:#fff}
.btn-green:hover{transform:translateY(-2px);box-shadow:0 6px 18px rgba(45,106,79,.3)}

/* Dot nav */
.dots{
  display:flex;flex-wrap:wrap;gap:.3rem;
  max-width:780px;width:100%;
}
.dot{
  width:26px;height:26px;border-radius:6px;border:none;
  font-size:.6rem;font-weight:500;cursor:pointer;transition:.15s;
  font-family:'DM Mono',monospace;
  background:var(--bg2);border:1px solid var(--border);color:var(--ink3);
}
.dot:hover{border-color:var(--accent);color:var(--accent)}
.dot.cur{background:var(--ink);color:var(--bg);border-color:var(--ink)}
.dot.d-ans{background:rgba(45,106,79,.15);color:var(--correct);border-color:rgba(45,106,79,.3)}
.dot.d-skp{background:rgba(184,134,11,.12);color:var(--gold);border-color:rgba(184,134,11,.3)}

/* ── MODAL ── */
.overlay{
  display:none;position:fixed;inset:0;
  background:rgba(26,22,18,.7);backdrop-filter:blur(8px);
  z-index:500;align-items:center;justify-content:center;padding:1rem;
}
.overlay.on{display:flex}
.modal{
  background:var(--card);border:1px solid var(--border);
  border-radius:20px;padding:2.5rem;max-width:400px;width:100%;
  text-align:center;
  box-shadow:0 30px 80px rgba(26,22,18,.25);
  animation:modalIn .25s ease;
}
@keyframes modalIn{from{transform:scale(.95);opacity:0}to{transform:scale(1);opacity:1}}
.modal-ico{font-size:2.5rem;margin-bottom:1rem}
.modal h3{font-family:'Playfair Display',serif;font-size:1.3rem;margin-bottom:.7rem}
.modal p{color:var(--ink3);font-size:.84rem;line-height:1.75;margin-bottom:1.8rem;white-space:pre-wrap}
.modal-row{display:flex;gap:.7rem;justify-content:center}

/* ── RESULTS ── */
#results{flex-direction:column;align-items:center;padding:2rem 1rem}
.res-shell{max-width:820px;width:100%}

.res-top{
  background:var(--card);border:1px solid var(--border);
  border-radius:20px;padding:3rem 2rem;text-align:center;
  margin-bottom:1.2rem;position:relative;overflow:hidden;
}
.res-top::before{
  content:'';position:absolute;bottom:-60px;left:50%;transform:translateX(-50%);
  width:300px;height:300px;border-radius:50%;
  background:radial-gradient(circle,rgba(200,75,47,.07),transparent 70%);
  pointer-events:none;
}

.res-score{
  font-family:'Playfair Display',serif;
  font-size:clamp(4rem,15vw,8rem);line-height:1;
  font-weight:700;color:var(--ink);margin-bottom:.3rem;
}
.res-score em{color:var(--accent);font-style:normal}
.res-total{font-size:.88rem;color:var(--ink3);margin-bottom:1.2rem}
.res-grade{
  display:inline-block;
  font-family:'Playfair Display',serif;font-size:1.1rem;font-weight:700;
  padding:.5rem 1.8rem;border-radius:50px;margin-bottom:.6rem;
}
.res-msg{color:var(--ink3);font-size:.85rem;max-width:380px;margin:0 auto}

/* Stats row */
.stats-row{
  display:grid;grid-template-columns:repeat(3,1fr);
  gap:.8rem;margin-bottom:1.2rem;
}
@media(max-width:480px){.stats-row{grid-template-columns:repeat(2,1fr)}}
.stat-c{
  background:var(--card);border:1px solid var(--border);
  border-radius:12px;padding:1.1rem .8rem;text-align:center;
  transition:.2s;
}
.stat-c:hover{transform:translateY(-2px);box-shadow:0 4px 16px rgba(26,22,18,.08)}
.stat-c-ico{font-size:1.2rem;margin-bottom:.3rem}
.stat-c-v{font-family:'Playfair Display',serif;font-size:1.5rem;font-weight:700;color:var(--ink)}
.stat-c-l{font-size:.62rem;text-transform:uppercase;letter-spacing:.08em;color:var(--ink3);margin-top:.2rem}

/* Insights */
.insights{
  background:var(--card);border:1px solid var(--border);
  border-radius:16px;padding:1.6rem;margin-bottom:1.2rem;
}
.ins-title{
  font-family:'Playfair Display',serif;font-size:.95rem;
  color:var(--ink);margin-bottom:1rem;
  display:flex;align-items:center;gap:.5rem;
}
.ins-line{
  font-size:.82rem;color:var(--ink2);
  margin-bottom:.55rem;line-height:1.7;
  padding-left:.8rem;border-left:2px solid var(--border);
}
.weak-tags{display:flex;flex-wrap:wrap;gap:.35rem;margin-top:.8rem}
.wt{
  font-size:.68rem;background:rgba(200,75,47,.08);
  color:var(--accent);padding:.22rem .65rem;border-radius:50px;
  border:1px solid rgba(200,75,47,.2);
}

/* Tabs & Review */
.tabs{
  display:flex;gap:.25rem;background:var(--bg2);
  border:1px solid var(--border);border-radius:10px;padding:.3rem;
  margin-bottom:.9rem;
}
.tab{
  flex:1;padding:.45rem;border:none;border-radius:7px;
  background:transparent;font-family:'DM Sans',sans-serif;
  font-size:.72rem;cursor:pointer;color:var(--ink3);transition:.2s;
}
.tab.on{background:var(--card);color:var(--ink);font-weight:500;box-shadow:0 1px 4px rgba(26,22,18,.08)}

.rev-card{
  background:var(--card);border:1px solid var(--border);
  border-radius:14px;padding:1.3rem;margin-bottom:.7rem;
  border-left:3px solid var(--border);
  animation:slideUp .3s ease;
  transition:transform .2s;
}
.rev-card:hover{transform:translateX(3px)}
.rev-card.rc{border-left-color:var(--correct)}
.rev-card.rw{border-left-color:var(--accent)}
.rev-card.rs{border-left-color:var(--gold)}

.rev-top{display:flex;flex-wrap:wrap;gap:.4rem;align-items:center;margin-bottom:.75rem}
.rv-n{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--ink3);background:var(--bg2);padding:.2rem .55rem;border-radius:50px;border:1px solid var(--border)}
.rv-yr{font-family:'DM Mono',monospace;font-size:.62rem;color:var(--gold);background:rgba(184,134,11,.07);padding:.2rem .55rem;border-radius:50px;border:1px solid rgba(184,134,11,.2)}
.rv-badge{font-size:.62rem;font-weight:600;padding:.2rem .6rem;border-radius:50px}
.rv-badge.rc{background:rgba(45,106,79,.1);color:var(--correct)}
.rv-badge.rw{background:rgba(200,75,47,.1);color:var(--accent)}
.rv-badge.rs{background:rgba(184,134,11,.1);color:var(--gold)}
.rv-top2{margin-left:auto;font-size:.62rem;color:var(--ink3);background:var(--bg2);padding:.2rem .55rem;border-radius:50px}

.rv-q{font-size:.82rem;color:var(--ink3);margin-bottom:.8rem;line-height:1.7;white-space:pre-wrap}
.rv-map{max-width:200px;border-radius:8px;border:1px solid var(--border);margin:.5rem 0;display:block}
.rv-row{display:flex;gap:.5rem;font-size:.78rem;margin-bottom:.28rem;align-items:flex-start}
.rv-lbl{font-weight:500;min-width:115px;color:var(--ink3);flex-shrink:0}
.rv-val{color:var(--ink)}
.rv-val.good{color:var(--correct)}
.rv-val.bad{color:var(--accent)}
.rv-exp{margin-top:.75rem;padding:.8rem .95rem;background:var(--bg2);border:1px solid var(--border);border-radius:8px;font-size:.78rem;color:var(--ink2);line-height:1.7}
.rv-exp strong{color:var(--ink);font-weight:600}

.res-btns{display:flex;gap:.8rem;justify-content:center;margin:1.8rem 0;flex-wrap:wrap}
.btn-accent{background:var(--accent);color:#fff;padding:.8rem 1.8rem;border-radius:50px;border:none;font-family:'DM Sans',sans-serif;font-size:.85rem;font-weight:500;cursor:pointer;transition:.2s}
.btn-accent:hover{transform:translateY(-2px);box-shadow:0 8px 22px rgba(200,75,47,.3)}

::-webkit-scrollbar{width:4px}
::-webkit-scrollbar-track{background:var(--bg2)}
::-webkit-scrollbar-thumb{background:var(--border);border-radius:10px}
::-webkit-scrollbar-thumb:hover{background:var(--ink3)}

@media(max-width:600px){
  .s-stats{flex-direction:column}
  .s-stat{border-right:none;border-bottom:1px solid var(--border)}
  .s-stat:last-child{border-bottom:none}
  .q-card{padding:1.3rem}
  .q-nav{flex-direction:column}
  .modal-row{flex-direction:column}
  .res-score{font-size:5rem}
}
</style>
</head>
<body>

<!-- ═══ START ═══ -->
<div id="start" class="screen active">
  <div class="s-eyebrow">UPSC Prelims · World Geography · PYQ</div>
  <h1 class="s-title">Geo<em>Mind</em></h1>
  <p class="s-sub">34 carefully curated questions from 1995–2023 UPSC Prelims. Continents, capitals, rivers, minerals, climate zones & more.</p>

  <div class="s-stats">
    <div class="s-stat"><div class="s-stat-v">34</div><div class="s-stat-l">Questions</div></div>
    <div class="s-stat"><div class="s-stat-v">25 min</div><div class="s-stat-l">Timer</div></div>
    <div class="s-stat"><div class="s-stat-v">1995–2023</div><div class="s-stat-l">PYQ Era</div></div>
  </div>

  <button class="s-btn" onclick="startQuiz()"><span>Begin Quiz →</span></button>
  <p class="s-note">Progress auto-saved · Resume anytime</p>
</div>

<!-- ═══ QUIZ ═══ -->
<div id="quiz" class="screen">
  <div class="q-shell">
    <div class="q-header">
      <div class="q-counter">Question <span id="qCur">1</span> of <span id="qTot">34</span></div>
      <div class="q-timer" id="timerEl">25:00</div>
    </div>
    <div class="q-bar"><div class="q-fill" id="pFill" style="width:0%"></div></div>

    <div class="q-card">
      <div class="q-meta">
        <span class="q-num" id="qBadge">Q01</span>
        <span class="q-yr" id="qYr">—</span>
        <span class="q-topic" id="qTopic">—</span>
        <span class="q-status-tag qs-none" id="qStat">Unanswered</span>
      </div>
      <div class="q-body" id="qBody"></div>
      <div class="map-area" id="mapArea" style="display:none">
        <img id="mapImg" src="" alt="Map" onload="this.classList.add('in')" onerror="document.getElementById('mapArea').style.display='none'"/>
        <div class="map-cap" id="mapCap"></div>
      </div>
      <div class="opts" id="optsGrid"></div>
      <div class="q-nav">
        <div style="display:flex;gap:.5rem">
          <button class="btn btn-outline" id="btnPrev" onclick="go(-1)">← Prev</button>
          <button class="btn btn-skip" onclick="skipQ()">Skip</button>
        </div>
        <div style="display:flex;gap:.5rem">
          <button class="btn btn-dark" id="btnNext" onclick="go(1)">Next →</button>
          <button class="btn btn-green" id="btnSub" style="display:none" onclick="showMod()">Submit ✓</button>
        </div>
      </div>
    </div>

    <div class="dots" id="dotMap"></div>
  </div>
</div>

<!-- ═══ RESULTS ═══ -->
<div id="results" class="screen">
  <div class="res-shell">
    <div class="res-top">
      <div class="res-score"><em id="rScore">0</em><span style="font-size:.4em;color:var(--ink3)">/34</span></div>
      <div class="res-total" id="rSub"></div>
      <div class="res-grade" id="rGrade"></div>
      <p class="res-msg" id="rMsg"></p>
    </div>

    <div class="stats-row">
      <div class="stat-c"><div class="stat-c-ico">✓</div><div class="stat-c-v" id="stC" style="color:var(--correct)">0</div><div class="stat-c-l">Correct</div></div>
      <div class="stat-c"><div class="stat-c-ico">✗</div><div class="stat-c-v" id="stW" style="color:var(--accent)">0</div><div class="stat-c-l">Wrong</div></div>
      <div class="stat-c"><div class="stat-c-ico">—</div><div class="stat-c-v" id="stS" style="color:var(--gold)">0</div><div class="stat-c-l">Skipped</div></div>
      <div class="stat-c"><div class="stat-c-ico">◎</div><div class="stat-c-v" id="stAcc">—</div><div class="stat-c-l">Accuracy</div></div>
      <div class="stat-c"><div class="stat-c-ico">⊙</div><div class="stat-c-v" id="stTime">—</div><div class="stat-c-l">Time</div></div>
      <div class="stat-c"><div class="stat-c-ico">∿</div><div class="stat-c-v" id="stAvg">—</div><div class="stat-c-l">Avg/Q</div></div>
    </div>

    <div class="insights">
      <div class="ins-title">Analysis & Weak Areas</div>
      <div id="insBody"></div>
    </div>

    <div class="tabs">
      <button class="tab on" onclick="setTab('all',this)">All (34)</button>
      <button class="tab" onclick="setTab('correct',this)">✓ Correct</button>
